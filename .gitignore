# ============================================================
# .gitignore — Zebrahub-Multiome (public Resource repo)
# Keeps main lean and prevents re-bloat. NOTE: we DO track the
# rendered .ipynb notebooks (with outputs) — do not ignore *.ipynb.
# ============================================================

# IDE / OS
.idea/
.vscode/
.DS_Store

# Python cache / checkpoints
*.pyc
*.pyo
__pycache__/
.pytest_cache/
.ipynb_checkpoints/

# Large binary / data artifacts (never track)
*.h5ad
*.h5
*.zarr
*.loom
*.oracle
*.pkl
*.pickle
*.npy
*.npz
*.mtx
*.sqlite
*.bam
*.bai
*.bw
*.bigwig

# Logs
*.log
/logs/

# Generated figures (regenerable from notebooks/scripts)
figures/

# Large data / scratch / output dirs (root-anchored so Fig1_atlas_QC/data/ stays tracked)
/data/
scripts/save/
notebooks/EDA_peak_parts_list/outputs/
notebooks/EDA_peak_parts_list/logs/
notebooks/Fig_peak_umap/output/

# LiteMind caches / generated outputs
scripts/litemind_peak_analysis/.cache/
scripts/litemind_peak_analysis/results/
notebooks/Fig_peak_umap/llm_annotation/prompts/

# Internal / AI scaffolding & planning docs (not for publication)
CLAUDE.md
LITEMIND_INTEGRATION_PLAN.md
REFACTOR.md
plan_refactor_v2.md
.claude/
/docs/

# Secrets / environment
.env
.env.*
*.key
*.pem
credentials.json

# The 3 oversized notebooks are published as jupytext .py only (see README) — ignore their .ipynb
notebooks/Fig_peak_umap/02_01_hierarchical_clustering_peak_umap.ipynb
notebooks/Fig2_ATAC_RNA_correlation_metacells/Fig2_metacell_RNA_ATAC_dynamics_v2.ipynb
notebooks/Fig3_GRN_dynamics/Fig3_SI_GRN_similarity_quant.ipynb

# Regenerable LiteMind LLM prompt artifacts — preserved locally, removed from published history
notebooks/Fig_peak_umap/prompts/
notebooks/Fig_peak_umap/litemind_prompt_leiden_coarse/
